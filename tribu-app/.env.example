# ---- Supabase ----
# Tableau de bord Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Clé "service_role" (SECRÈTE, jamais exposée au navigateur) — utilisée par le webhook Stripe
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---- Stripe ----
# Tableau de bord Stripe > Developers > API keys (utilise les clés "test" pour commencer)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Secret du endpoint webhook (Stripe > Developers > Webhooks > ton endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- App ----
# URL publique de l'app (http://localhost:3000 en local, https://ton-app.vercel.app en prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000
